# ─── Backend URL ──────────────────────────────────────────────────────────────
# Local dev: leave blank (Vite proxy handles /api → localhost:3001)
# Production (Netlify): set to your Render/Railway backend URL
VITE_API_URL=

# ─── Optional: paste your Groq key here for frontend storage only ─────────────
# This is stored in browser localStorage only, never committed.
# Leave blank if you prefer to enter it in the app's Settings panel.
VITE_GROQ_API_KEY=
